---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { withBase, cleanSlug } from '../../lib/config';
import labels from '../../content/labels.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const galleries = (await getCollection('galleries'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Galleries">
  <h1 class="mb-8 text-2xl font-bold">{labels.galleries.heading}</h1>
  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
    {galleries.map((gallery) => (
      <a
        href={`${base}/galleries/${cleanSlug(gallery.id)}`}
        class="group overflow-hidden rounded-lg border border-theme-card-border bg-theme-card transition hover:border-theme-card-hover"
      >
        {gallery.data.coverImage && (
          <div class="aspect-video overflow-hidden">
            <img
              src={withBase(typeof gallery.data.coverImage === 'string' ? gallery.data.coverImage : gallery.data.coverImage.src)}
              alt={gallery.data.title}
              class="h-full w-full object-cover transition group-hover:scale-105"
              loading="lazy"
            />
          </div>
        )}
        <div class="p-4">
          <h3 class="font-medium">{gallery.data.title}</h3>
          <p class="mt-1 text-sm text-theme-muted">{gallery.data.photos.length} photos</p>
          {gallery.data.description && (
            <p class="mt-1 text-sm text-theme-faint line-clamp-2">{gallery.data.description}</p>
          )}
        </div>
      </a>
    ))}
  </div>
</BaseLayout>
